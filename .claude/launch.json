{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo (QR / Expo Go)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start"],
      "port": 8081
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "19006"],
      "port": 19006
    },
    {
      "name": "Expo iOS Simulator",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--ios"],
      "port": 8081
    },
    {
      "name": "Expo Android Emulator",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--android"],
      "port": 8081
    }
  ]
}
